# =============================================================================
# Bomberman Online - Local Development Environment
# =============================================================================
# Copy this file to .env.local for local development
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk Authentication (Development Keys)
# Get these from: https://dashboard.clerk.com
# Use "Development" instance for local development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_DEV_KEY
CLERK_SECRET_KEY=sk_test_YOUR_DEV_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# -----------------------------------------------------------------------------
# Supabase (Development Project)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Recommended: Use a separate Supabase project for development
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Game Server (Local Development)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:8080
GAME_SERVER_PORT=8080

# -----------------------------------------------------------------------------
# Feature Flags (All enabled for development)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FF_TOURNAMENTS=true
NEXT_PUBLIC_FF_REPLAYS=true
NEXT_PUBLIC_FF_MAP_EDITOR=true
NEXT_PUBLIC_FF_SPECTATOR=true

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Enable React Query devtools
# NEXT_PUBLIC_ENABLE_DEVTOOLS=true

# Enable debug logging
# DEBUG=bomberman:*
