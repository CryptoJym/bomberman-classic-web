{
  "name": "bomberman-online",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "play:classic": "zsh ./scripts/play-classic-mac.sh",
    "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "build:server": "tsc -p tsconfig.server.json",
    "test": "jest",
    "test:classic": "node --test tests/classic-server-port.test.cjs tests/classic-client-state.test.cjs tests/classic-client-input.test.cjs tests/classic-room-code.test.cjs tests/classic-room-isolation.test.cjs tests/classic-movement-cadence.test.cjs tests/classic-turn-buffering.test.cjs tests/classic-health.test.cjs tests/classic-cloud-manifest.test.cjs",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "db:generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > lib/supabase/types.ts",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@clerk/nextjs": "^5.0.0",
    "@supabase/ssr": "^0.3.0",
    "@supabase/supabase-js": "^2.43.0",
    "@tanstack/react-query": "^5.90.12",
    "clsx": "^2.1.0",
    "express": "^4.22.1",
    "framer-motion": "^12.23.26",
    "next": "^14.2.0",
    "pixi.js": "^8.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.8.1",
    "svix": "^1.82.0",
    "tailwind-merge": "^2.3.0",
    "ws": "^8.17.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "prettier-plugin-tailwindcss": "^0.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
